<div class="card-body">
  <h5 class="card-title">Wochenplan</h5>

  <div tal:repeat="day days" class="mb-3">
    <h6 class="${'fw-bold' if day.is_today() else 'fw-light'}">${format.date(day.day, "full")}</h6>

    <p class="${'fw-bold' if day.is_today() else ''}">
    <tal:block condition="day.dinner">
      #${day.dinner_id} – ${day.dinner.title}

      <a tal:condition="day.dinner.recipe"
        href="${request.route_url('recipe_steps', id=day.dinner.id)}" target="_blank">
        📄
      </a>
      <a tal:condition="not day.dinner.recipe and day.dinner.source_url"
        href="${day.dinner.source_url}">📄</a>
    </tal:block>

    <tal:block condition="not:day.dinner">
      ${day.dinner_freestyle}
    </tal:block>
    </p>
    <p tal:condition="day.note" class="fw-light fst-italic">${day.note}</p>
  </div>
</div>
