<table class="table table-sm">
  <thead>
    <tr>
      <th>Verbindung</th>
      <th class="text-end">Abfahrt</th>
      <th class="text-end">Ankunft</th>
    </tr>
  </thead>
  <tbody class="fw-light">
    <tr tal:repeat="journey journeys">
      <td class="align-top">${journey.lines}</td>
      <td class="text-end align-top">${journey.whenRelative}</td>
      <td class="text-end align-top">${journey.arrives}</td>
    </tr>
  </tbody>
</table>
