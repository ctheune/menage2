<!DOCTYPE html metal:define-macro="layout">
<html lang="${request.locale_name}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Menage 2</title>

    <link href="data:image/x-icon;base64,iVBORw0KGgoAAAANSUhEUgAAABAAAAAQEAYAAABPYyMiAAAABmJLR0T///////8JWPfcAAAACXBIWXMAAABIAAAASABGyWs+AAAAF0lEQVRIx2NgGAWjYBSMglEwCkbBSAcACBAAAeaR9cIAAAAASUVORK5CYII=" rel="icon" type="image/x-icon" />
    <link rel="apple-touch-icon" href="${request.static_url('menage2:static/applogo.png')}">
    <meta name="apple-mobile-web-app-title" content="Menage">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <link href="${request.static_url('menage2:static/bootstrap.min.css')}" rel="stylesheet">
    <link href="${request.static_url('menage2:static/bootstrap-icons.min.css')}" rel="stylesheet">
    <link href="${request.static_url('menage2:static/theme.css')}" rel="stylesheet">

    <script src="${request.static_url('menage2:static/htmx.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/hyperscript.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/bootstrap.bundle.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/menage.js')}" defer></script>
  </head>

  <body class="bg-body-secondary" hx-boost="true">

  <nav class="navbar navbar-expand-md navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="${request.route_url('home')}">Menage</a>
      <span class="navbar-text d-md-none small">
        <metal:block define-slot="title-mobile"></metal:block>
      </span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-links" aria-controls="nav-links" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav-links">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item"><a class="nav-link" href="${request.route_url('list_recipes')}">Rezepte</a></li>
          <li class="nav-item"><a class="nav-link" href="${request.route_url('list_ingredients')}">Zutaten</a></li>
          <li class="nav-item"><a class="nav-link" href="${request.route_url('list_weeks')}">Wochenpläne</a></li>
          <li class="nav-item"><a class="nav-link" href="${request.route_url('list_todos')}">TODO</a></li>
          <tal:block tal:condition="request.identity is not None and request.identity.is_admin">
            <li class="nav-item"><a class="nav-link" href="${request.route_url('admin_users')}">Admin</a></li>
          </tal:block>
          <tal:block tal:condition="request.identity is not None">
            <li class="nav-item"><a class="nav-link text-secondary" href="${request.route_url('account')}">${request.identity.username}</a></li>
            <li class="nav-item">
              <form method="post" action="${request.route_url('logout')}" class="d-inline">
                <button type="submit" class="nav-link btn btn-link text-secondary">Sign out</button>
              </form>
            </li>
          </tal:block>
          <tal:block tal:condition="request.identity is None">
            <li class="nav-item"><a class="nav-link" href="${request.route_url('login')}">Login</a></li>
          </tal:block>
        </ul>
      </div>
    </div>
  </nav>

  <div class="d-none d-md-block bg-white border-bottom">
    <div class="px-3 py-2 d-flex align-items-center justify-content-between">
      <h4 class="mb-0 lh-base">
        <metal:block define-slot="title">Der unendliche Speiseplan</metal:block>
      </h4>
      <div class="d-flex gap-2">
        <metal:block define-slot="actions"></metal:block>
      </div>
    </div>
    <metal:block define-slot="subtitle"></metal:block>
  </div>

  <div metal:define-slot="content">No content</div>

  </body>
</html>
