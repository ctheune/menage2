<!DOCTYPE html metal:define-macro="layout">
<html lang="${request.locale_name}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>${base_name}</title>
    <link rel="icon" type="image/svg+xml" href="${request.static_url('menage2:static/logo.svg')}" />
    <link rel="apple-touch-icon" href="${request.static_url('menage2:static/logo.png')}">
    <meta name="apple-mobile-web-app-title" tal:attributes="content base_name">
    <meta name="apple-mobile-web-app-capable" content="yes">

    <link href="${request.static_url('menage2:static/bootstrap.min.css')}" rel="stylesheet">
    <link href="${request.static_url('menage2:static/bootstrap-icons.min.css')}" rel="stylesheet">
    <link href="${request.static_url('menage2:static/theme.css')}" rel="stylesheet">

    <script src="${request.static_url('menage2:static/htmx.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/hyperscript.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/bootstrap.bundle.min.js')}" defer></script>
    <script src="${request.static_url('menage2:static/composite-input.js')}" defer></script>
    <script src="${request.static_url('menage2:static/menage.js')}" defer></script>
    <meta name="theme-color" content="#04081A">
  </head>

  <body hx-boost="true"
        data-tags-url="${request.route_url('list_tags_json')}"
        data-top-tags-url="${request.route_url('list_top_tags_json')}">

  <tal:block tal:define="
    route_name python:request.matched_route.name if request.matched_route else '';
    in_food python:route_name in ('list_recipes', 'add_recipe', 'edit_recipe', 'recipe_steps', 'list_ingredients', 'ingredient_recipes', 'ingredient_toggle_tag', 'suggest_ingredient', 'list_weeks', 'add_week', 'edit_week', 'add_day', 'send_to_shopping_list', 'set_dinner', 'toggle_day_shopping', 'delete_day', 'planner', 'letscook');
    in_tasks python:route_name in ('list_todos', 'list_todos_done', 'list_todos_scheduled', 'list_todos_hold', 'add_todo', 'edit_todo', 'todos_done', 'todos_hold', 'todos_postpone', 'todos_activate_all_on_hold', 'todo_undo', 'todos_activate_batch', 'set_due_date', 'parse_date_preview', 'set_recurrence', 'parse_recurrence_preview', 'recurrence_history', 'list_tags_json', 'list_principals_json', 'list_protocols', 'new_protocol', 'edit_protocol', 'archive_protocol', 'unarchive_protocol', 'add_protocol_item', 'update_protocol_item', 'update_protocol_item_partial', 'delete_protocol_item', 'start_protocol_run', 'show_protocol_run', 'list_protocols_palette');
    in_operations python:route_name in ('admin_operations', 'admin_users', 'admin_user_new', 'admin_user_edit', 'admin_user_deactivate', 'admin_user_delete', 'admin_teams', 'admin_team_new', 'admin_team_edit', 'admin_team_delete', 'admin_team_member_add', 'admin_team_member_remove', 'admin_dashboard_token', 'admin_recurrence_sweep', 'admin_composite_playground');
    in_section python:in_food or in_tasks or in_operations;
    sub_meal python:route_name in ('list_weeks', 'add_week', 'edit_week', 'add_day', 'send_to_shopping_list', 'set_dinner', 'toggle_day_shopping', 'delete_day', 'planner', 'letscook');
    sub_recipes python:route_name in ('list_recipes', 'add_recipe', 'edit_recipe', 'recipe_steps');
    sub_ingredients python:route_name in ('list_ingredients', 'ingredient_recipes', 'ingredient_toggle_tag', 'suggest_ingredient');
    sub_todo_active python:route_name in ('list_todos', 'add_todo', 'edit_todo', 'todos_done', 'todos_hold', 'todos_postpone', 'todos_activate_all_on_hold', 'todo_undo', 'todos_activate_batch', 'set_due_date', 'parse_date_preview', 'set_recurrence', 'parse_recurrence_preview', 'recurrence_history', 'list_tags_json', 'list_principals_json');
    sub_todo_hold python:route_name == 'list_todos_hold';
    sub_todo_scheduled python:route_name == 'list_todos_scheduled';
    sub_todo_done python:route_name == 'list_todos_done';
    sub_protocols python:route_name in ('list_protocols', 'new_protocol', 'edit_protocol', 'archive_protocol', 'unarchive_protocol', 'add_protocol_item', 'update_protocol_item', 'update_protocol_item_partial', 'delete_protocol_item', 'start_protocol_run', 'show_protocol_run', 'list_protocols_palette');
    sub_crew python:route_name in ('admin_users', 'admin_user_new', 'admin_user_edit', 'admin_user_deactivate', 'admin_user_delete');
    sub_departments python:route_name in ('admin_teams', 'admin_team_new', 'admin_team_edit', 'admin_team_delete', 'admin_team_member_add', 'admin_team_member_remove');
    sub_admin_ops python:route_name in ('admin_operations', 'admin_dashboard_token', 'admin_recurrence_sweep', 'admin_composite_playground')
  ">

  <div class="helios-header">
  <nav class="navbar navbar-expand-md navbar-dark">
    <div class="container-fluid">
      <a class="navbar-brand d-flex align-items-center gap-2" href="${request.route_url('home')}"><img src="${request.static_url('menage2:static/logo.svg')}" height="28" tal:attributes="alt base_name" style="border-radius: 6px;">${base_name}</a>
      <span class="navbar-text d-md-none small">
        <metal:block define-slot="title-mobile"></metal:block>
      </span>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav-links" aria-controls="nav-links" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="nav-links">
        <ul class="navbar-nav me-auto">
          <tal:block tal:condition="request.identity is not None">
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if in_food else 'nav-link'"
                 href="${request.route_url('list_weeks')}">
                <i class="bi bi-basket2"></i> Food
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if in_tasks else 'nav-link'"
                 href="${request.route_url('list_todos')}">
                <i class="bi bi-list-check"></i> Tasks
              </a>
            </li>
            <tal:block tal:condition="request.identity.is_admin">
              <li class="nav-item">
                <a class="nav-link" tal:attributes="class python:'nav-link active' if in_operations else 'nav-link'"
                   href="${request.route_url('admin_users')}">
                  <i class="bi bi-gear"></i> Operations
                </a>
              </li>
            </tal:block>
          </tal:block>
        </ul>
        <ul class="navbar-nav ms-auto align-items-center gap-2">
          <tal:block tal:condition="request.identity is not None">
            <li class="nav-item">
              <a class="btn btn-sm btn-outline-light" href="${request.route_url('account')}"><i class="bi bi-person"></i>  ${request.identity.username}</a>
            </li>
            <li class="nav-item">
              <form method="post" action="${request.route_url('logout')}" class="m-0">
                <button type="submit" class="btn btn-sm btn-outline-light"><i class="bi bi-door-open"></i> Log off</button>
              </form>
            </li>
          </tal:block>
          <tal:block tal:condition="request.identity is None">
            <li class="nav-item"><a class="nav-link" href="${request.route_url('login')}">Login</a></li>
          </tal:block>
        </ul>
      </div>
    </div>
  </nav>

  <div class="d-none d-md-block helios-subnav">
    <div class="px-3 py-1 d-flex align-items-center justify-content-between">

      <!-- Section sub-navigation -->
      <tal:block tal:condition="in_section">
        <ul class="nav nav-tabs border-0">

          <tal:block tal:condition="in_food">
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_meal else 'nav-link'"
                 href="${request.route_url('list_weeks')}">Meal Planner</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_recipes else 'nav-link'"
                 href="${request.route_url('list_recipes')}">Recipes</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_ingredients else 'nav-link'"
                 href="${request.route_url('list_ingredients')}">Ingredients</a>
            </li>
          </tal:block>

          <tal:block tal:condition="in_tasks">
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_todo_active else 'nav-link'"
                 href="${request.route_url('list_todos')}">
                Active
                <span tal:condition="python:nav_task_counts and nav_task_counts['active']"
                      class="badge rounded-pill bg-dark ms-1">
                  ${nav_task_counts['active']}
                </span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_todo_hold else 'nav-link'"
                 href="${request.route_url('list_todos_hold')}">
                On Hold
                <span tal:condition="python:nav_task_counts and nav_task_counts['hold']"
                      class="badge rounded-pill bg-secondary ms-1">
                  ${nav_task_counts['hold']}
                </span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_todo_scheduled else 'nav-link'"
                 href="${request.route_url('list_todos_scheduled')}">
                Scheduled
                <span tal:condition="python:nav_task_counts and nav_task_counts['scheduled']"
                      class="badge rounded-pill bg-primary ms-1">
                  ${nav_task_counts['scheduled']}
                </span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_todo_done else 'nav-link'"
                 href="${request.route_url('list_todos_done')}">Done</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_protocols else 'nav-link'"
                 href="${request.route_url('list_protocols')}">Protocols</a>
            </li>
          </tal:block>

          <tal:block tal:condition="in_operations">
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_crew else 'nav-link'"
                 href="${request.route_url('admin_users')}">Crew</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_departments else 'nav-link'"
                 href="${request.route_url('admin_teams')}">Departments</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" tal:attributes="class python:'nav-link active' if sub_admin_ops else 'nav-link'"
                 href="${request.route_url('admin_operations')}">Maintenance</a>
            </li>
          </tal:block>

        </ul>
      </tal:block>

      <!-- Standalone page title (login, account, setup, etc.) -->
      <tal:block tal:condition="not in_section">
        <h4 class="mb-0 lh-base">
          <metal:block define-slot="title">Menage</metal:block>
        </h4>
      </tal:block>

      <div class="d-flex gap-2">
        <metal:block define-slot="actions"></metal:block>
      </div>
    </div>
    <metal:block define-slot="subtitle"></metal:block>
  </div>
  </div><!-- /.helios-header -->

  <div class="helios-content-wrap">
    <div metal:define-slot="content">No content</div>
  </div>

  </tal:block>

  <div class="modal fade" id="attachmentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-fullscreen-sm-down modal-xl modal-dialog-centered">
      <div class="modal-content bg-dark">
        <div class="modal-header border-0 pb-0">
          <span id="attachmentModalCounter" class="text-white-50 small me-auto"></span>
          <button type="button" class="btn-close btn-close-white btn-lg"
                  data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-0 d-flex align-items-center justify-content-center position-relative">
          <button id="attachmentModalPrev" type="button"
                  class="btn btn-link position-absolute start-0 top-50 translate-middle-y text-white px-3 py-4"
                  aria-label="Previous" style="font-size:2.5rem;line-height:1">&#8249;</button>
          <img id="attachmentModalImage" src="" alt=""
               class="img-fluid" style="max-height:90vh;object-fit:contain" />
          <button id="attachmentModalNext" type="button"
                  class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-white px-3 py-4"
                  aria-label="Next" style="font-size:2.5rem;line-height:1">&#8250;</button>
        </div>
      </div>
    </div>
  </div>

  </body>
</html>
