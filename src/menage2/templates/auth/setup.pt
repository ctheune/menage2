<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Setup</span>
  <div metal:fill-slot="title">First-Time Setup</div>

  <div metal:fill-slot="content" class="px-4 py-8 max-w-sm mx-auto">

    <!-- Stage 1: token entry -->
    <tal:block tal:condition="stage == 'token'">
      <p class="text-slate-600 text-sm mb-6">
        Enter the one-time setup token printed in the server log to continue.
      </p>
      <tal:block tal:condition="token_error is not None">
        <p class="text-red-600 text-sm mb-4">${token_error}</p>
      </tal:block>
      <form method="post" action="${request.route_url('setup')}" class="space-y-4">
        <div>
          <label for="token" class="block text-sm font-medium text-slate-700 mb-1">Setup Token</label>
          <input type="text" id="token" name="token" required autofocus
                 autocomplete="off" spellcheck="false"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-slate-500" />
        </div>
        <button type="submit"
                class="w-full bg-slate-700 hover:bg-slate-800 text-white font-medium py-2 px-4 rounded text-sm">
          Continue
        </button>
      </form>
    </tal:block>

    <!-- Stage 2: admin account form -->
    <tal:block tal:condition="stage == 'form'">
      <p class="text-slate-600 text-sm mb-6">
        No users exist yet. Create the first administrator account to get started.
      </p>
      <form method="post" action="${request.route_url('setup')}" class="space-y-4">
        <input type="hidden" name="token" value="${token}" />

        <div>
          <label for="real_name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
          <input type="text" id="real_name" name="real_name" required autofocus
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'real_name' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['real_name']}</p>
          </tal:block>
        </div>

        <div>
          <label for="username" class="block text-sm font-medium text-slate-700 mb-1">Username</label>
          <input type="text" id="username" name="username" required autocomplete="username"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'username' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['username']}</p>
          </tal:block>
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'email' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['email']}</p>
          </tal:block>
        </div>

        <div>
          <label for="password" class="block text-sm font-medium text-slate-700 mb-1">Password</label>
          <input type="password" id="password" name="password" required autocomplete="new-password"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'password' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['password']}</p>
          </tal:block>
        </div>

        <div>
          <label for="confirm_password" class="block text-sm font-medium text-slate-700 mb-1">Confirm Password</label>
          <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'confirm_password' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['confirm_password']}</p>
          </tal:block>
        </div>

        <button type="submit"
                class="w-full bg-slate-700 hover:bg-slate-800 text-white font-medium py-2 px-4 rounded text-sm">
          Create Admin Account
        </button>
      </form>
    </tal:block>

  </div>
</div>
