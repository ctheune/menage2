<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Setup</span>
  <div metal:fill-slot="title">First-Time Setup</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-5 col-lg-4">

        <!-- Stage 1: token entry -->
        <tal:block tal:condition="stage == 'token'">
          <p class="text-muted mb-4">Enter the one-time setup token printed in the server log to continue.</p>
          <tal:block tal:condition="token_error is not None">
            <div class="alert alert-danger">${token_error}</div>
          </tal:block>
          <form method="post" action="${request.route_url('setup')}">
            <div class="mb-3">
              <label for="token" class="form-label">Setup Token</label>
              <input type="text" id="token" name="token" required autofocus
                     autocomplete="off" spellcheck="false" class="form-control font-monospace" />
            </div>
            <button type="submit" class="btn btn-dark w-100">Continue</button>
          </form>
        </tal:block>

        <!-- Stage 2: admin account form -->
        <tal:block tal:condition="stage == 'form'">
          <p class="text-muted mb-4">No users exist yet. Create the first administrator account to get started.</p>
          <form method="post" action="${request.route_url('setup')}">
            <input type="hidden" name="token" value="${token}" />

            <div class="mb-3">
              <label for="real_name" class="form-label">Full Name</label>
              <input type="text" id="real_name" name="real_name" required autofocus class="form-control" />
              <tal:block tal:condition="'real_name' in errors">
                <p class="text-danger small mt-1">${errors['real_name']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" id="username" name="username" required autocomplete="username" class="form-control" />
              <tal:block tal:condition="'username' in errors">
                <p class="text-danger small mt-1">${errors['username']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" class="form-control" />
              <tal:block tal:condition="'email' in errors">
                <p class="text-danger small mt-1">${errors['email']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password" id="password" name="password" required autocomplete="new-password" class="form-control" />
              <tal:block tal:condition="'password' in errors">
                <p class="text-danger small mt-1">${errors['password']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="confirm_password" class="form-label">Confirm Password</label>
              <input type="password" id="confirm_password" name="confirm_password" required autocomplete="new-password" class="form-control" />
              <tal:block tal:condition="'confirm_password' in errors">
                <p class="text-danger small mt-1">${errors['confirm_password']}</p>
              </tal:block>
            </div>

            <button type="submit" class="btn btn-dark w-100">Create Admin Account</button>
          </form>
        </tal:block>

      </div>
    </div>
  </div>
</div>
