<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Forgot Password</span>
  <div metal:fill-slot="title">Password Recovery</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-5 col-lg-4">

        <tal:block tal:condition="submitted">
          <div class="alert alert-success">
            If an account with that email exists, a password reset link has been sent.
            Please check your inbox.
          </div>
          <a href="${request.route_url('login')}" class="link-secondary">← Back to login</a>
        </tal:block>

        <tal:block tal:condition="not submitted">
          <p class="text-muted mb-4">Enter your email address and we'll send you a link to reset your password.</p>

          <form method="post" action="${request.route_url('forgot_password')}">
            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" name="email" required autofocus autocomplete="email"
                     class="form-control" />
            </div>

            <button type="submit" class="btn btn-dark w-100">Send Reset Link</button>
          </form>

          <div class="text-center mt-3">
            <a href="${request.route_url('login')}" class="link-secondary">← Back to login</a>
          </div>
        </tal:block>

      </div>
    </div>
  </div>
</div>
