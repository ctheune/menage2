<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Forgot Password</span>
  <div metal:fill-slot="title">Password Recovery</div>

  <div metal:fill-slot="content" class="px-4 py-8 max-w-sm mx-auto">

    <tal:block tal:condition="submitted">
      <div class="bg-green-50 border border-green-400 text-green-800 px-4 py-3 rounded mb-4">
        If an account with that email exists, a password reset link has been sent.
        Please check your inbox.
      </div>
      <a href="${request.route_url('login')}" class="text-sm text-slate-600 hover:underline">← Back to login</a>
    </tal:block>

    <tal:block tal:condition="not submitted">
      <p class="text-slate-600 text-sm mb-6">
        Enter your email address and we'll send you a link to reset your password.
      </p>

      <form method="post" action="${request.route_url('forgot_password')}" class="space-y-4">
        <div>
          <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required autofocus autocomplete="email"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
        </div>

        <button type="submit"
                class="w-full bg-slate-700 hover:bg-slate-800 text-white font-medium py-2 px-4 rounded text-sm">
          Send Reset Link
        </button>
      </form>

      <div class="mt-4 text-center text-sm">
        <a href="${request.route_url('login')}" class="text-slate-600 hover:underline">← Back to login</a>
      </div>
    </tal:block>

  </div>
</div>
