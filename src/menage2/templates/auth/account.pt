<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Account</span>
  <div metal:fill-slot="title">My Account</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-md-7 col-lg-5">

        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title">Profile</h5>
            <dl class="row mb-0">
              <dt class="col-4 text-muted">Name</dt><dd class="col-8">${user.real_name}</dd>
              <dt class="col-4 text-muted">Username</dt><dd class="col-8">${user.username}</dd>
              <dt class="col-4 text-muted">Email</dt><dd class="col-8">${user.email}</dd>
              <tal:block tal:condition="user.is_admin">
                <dt class="col-4 text-muted">Role</dt><dd class="col-8 text-primary">Administrator</dd>
              </tal:block>
            </dl>
          </div>
        </div>

        <div class="card mb-3">
          <div class="card-body">
            <h5 class="card-title">Security</h5>
            <ul class="list-unstyled mb-0">
              <li><a href="${request.route_url('account_change_password')}" class="link-dark">Change Password</a></li>
              <li class="mt-1"><a href="${request.route_url('account_passkeys')}" class="link-dark">Manage Passkeys</a></li>
            </ul>
          </div>
        </div>

        <form method="post" action="${request.route_url('logout')}">
          <button type="submit" class="btn btn-link text-danger p-0">Sign out</button>
        </form>

      </div>
    </div>
  </div>
</div>
