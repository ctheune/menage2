<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Change Password</span>
  <div metal:fill-slot="title">Change Password</div>

  <div metal:fill-slot="content" class="px-4 py-8 max-w-sm mx-auto">

    <tal:block tal:condition="success">
      <div class="bg-green-50 border border-green-400 text-green-800 px-4 py-3 rounded mb-4">
        Password changed successfully.
      </div>
      <a href="${request.route_url('account')}" class="text-sm text-slate-600 hover:underline">← Back to account</a>
    </tal:block>

    <tal:block tal:condition="not success">
      <form method="post" action="${request.route_url('account_change_password')}" class="space-y-4">

        <div>
          <label for="current_password" class="block text-sm font-medium text-slate-700 mb-1">Current Password</label>
          <input type="password" id="current_password" name="current_password" required autofocus
                 autocomplete="current-password"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'current_password' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['current_password']}</p>
          </tal:block>
        </div>

        <div>
          <label for="new_password" class="block text-sm font-medium text-slate-700 mb-1">New Password</label>
          <input type="password" id="new_password" name="new_password" required
                 autocomplete="new-password"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'new_password' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['new_password']}</p>
          </tal:block>
        </div>

        <div>
          <label for="confirm_password" class="block text-sm font-medium text-slate-700 mb-1">Confirm New Password</label>
          <input type="password" id="confirm_password" name="confirm_password" required
                 autocomplete="new-password"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'confirm_password' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['confirm_password']}</p>
          </tal:block>
        </div>

        <button type="submit"
                class="w-full bg-slate-700 hover:bg-slate-800 text-white font-medium py-2 px-4 rounded text-sm">
          Change Password
        </button>
      </form>

      <div class="mt-4 text-center text-sm">
        <a href="${request.route_url('account')}" class="text-slate-600 hover:underline">← Back to account</a>
      </div>
    </tal:block>

  </div>
</div>
