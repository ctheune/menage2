<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Change Password</span>
  <div metal:fill-slot="title">Change Password</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-5 col-lg-4">

        <tal:block tal:condition="success">
          <div class="alert alert-success">Password changed successfully.</div>
          <a href="${request.route_url('account')}" class="link-secondary">← Back to account</a>
        </tal:block>

        <tal:block tal:condition="not success">
          <form method="post" action="${request.route_url('account_change_password')}">

            <div class="mb-3">
              <label for="current_password" class="form-label">Current Password</label>
              <input type="password" id="current_password" name="current_password" required autofocus
                     autocomplete="current-password" class="form-control" />
              <tal:block tal:condition="'current_password' in errors">
                <p class="text-danger small mt-1">${errors['current_password']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="new_password" class="form-label">New Password</label>
              <input type="password" id="new_password" name="new_password" required
                     autocomplete="new-password" class="form-control" />
              <tal:block tal:condition="'new_password' in errors">
                <p class="text-danger small mt-1">${errors['new_password']}</p>
              </tal:block>
            </div>

            <div class="mb-3">
              <label for="confirm_password" class="form-label">Confirm New Password</label>
              <input type="password" id="confirm_password" name="confirm_password" required
                     autocomplete="new-password" class="form-control" />
              <tal:block tal:condition="'confirm_password' in errors">
                <p class="text-danger small mt-1">${errors['confirm_password']}</p>
              </tal:block>
            </div>

            <button type="submit" class="btn btn-dark w-100">Change Password</button>
          </form>

          <div class="text-center mt-3">
            <a href="${request.route_url('account')}" class="link-secondary">← Back to account</a>
          </div>
        </tal:block>

      </div>
    </div>
  </div>
</div>
