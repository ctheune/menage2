<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Login</span>
  <div metal:fill-slot="title">Login</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-5 col-lg-4">

        <tal:block tal:condition="error is not None">
          <div class="alert alert-danger" role="alert">
            ${error}
          </div>
        </tal:block>

        <form method="post" action="${request.route_url('login')}">
          <input type="hidden" name="came_from" value="${came_from}" />

          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" id="username" name="username" required autofocus
                   autocomplete="username" class="form-control" />
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="password" id="password" name="password"
                   autocomplete="current-password" class="form-control" />
          </div>

          <button type="submit" class="btn btn-dark w-100">Sign in</button>
        </form>

        <div class="text-center my-3 text-muted">or</div>

        <button id="passkey-btn" type="button"
                class="btn btn-outline-secondary w-100 d-flex align-items-center justify-content-center gap-2"
                onclick="passkeyLogin()">
          <i class="bi bi-key"></i> Sign in with Passkey
        </button>
        <p id="passkey-error" class="mt-2 text-danger d-none"></p>

        <div class="mt-4 text-center">
          <a href="${request.route_url('forgot_password')}" class="link-secondary">Forgot password?</a>
        </div>

        <script src="${request.static_url('menage2:static/passkeys.js')}"></script>
        <script>
          function passkeyLogin() {
            const btn = document.getElementById('passkey-btn');
            const errEl = document.getElementById('passkey-error');
            btn.disabled = true;
            errEl.classList.add('d-none');
            startPasskeyLogin(
              '${request.route_url("login_passkey_begin")}',
              '${request.route_url("login_passkey_complete")}'
            ).catch(err => {
              errEl.textContent = err.message || 'Passkey sign-in failed.';
              errEl.classList.remove('d-none');
            }).finally(() => {
              btn.disabled = false;
            });
          }
        </script>
      </div>
    </div>
  </div>
</div>
