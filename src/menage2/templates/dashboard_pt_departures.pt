<table class="table table-sm">
  <thead>
    <tr>
      <th>Linie</th>
      <th>Richtung</th>
      <th class="text-end">Abfahrt</th>
    </tr>
  </thead>
  <tbody class="fw-light">
    <tr tal:repeat="departure departures">
      <td class="align-top">${departure.line}</td>
      <td class="align-top">${departure.direction}</td>
      <td class="text-end align-top">${departure.whenRelative}</td>
    </tr>
  </tbody>
</table>
