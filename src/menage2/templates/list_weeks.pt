<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title">Wochenpläne</span>

  <span metal:fill-slot="actions">
    <button
        type="submit"
        class="btn btn-sm btn-dark text-nowrap"
        value="Neue Woche"
        hx-target="body"
        hx-push-url="true"
        hx-put="${request.route_url('add_week')}">
        <i class="bi bi-calendar-week"></i>
        New week
    </button>
  </span>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">
    <p tal:condition="not weeks" class="text-muted fst-italic">
      Noch keine Wochenpläne vorhanden.
      <input type="button"
          value="Erste Woche anlegen"
          hx-target="body"
          hx-push-url="true"
          hx-put="${request.route_url('add_week')}"
          class="btn btn-sm btn-outline-secondary ms-2" />
    </p>
    <ul class="list-group">
      <li tal:repeat="week weeks" class="list-group-item">
        <a href="${request.route_url('edit_week', id=week.id)}">Woche vom ${format.date(week.first.day, "long")} – ${format.date(week.last.day, "long")}</a>
      </li>
    </ul>
  </div>
</div>
