<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title-mobile">TODO</span>
  <div metal:fill-slot="title">TODO</div>

  <div metal:fill-slot="content" class="px-4 py-4 max-w-2xl">

    <!-- Add todo form -->
    <form hx-post="${request.route_url('add_todo')}"
          hx-target="body"
          class="mb-3">
      <input type="text" name="text" autocomplete="off"
             enterkeyhint="done"
             placeholder="New todo… #tag #category:sub"
             style="width:100%"
             class="rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-cyan-400" />
    </form>

    <!-- Secondary action bar: postponed + done (OOB target must keep id) -->
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1rem;">
      <div id="postponed-section">
        <tal:block tal:condition="postponed_count > 0">
          <button hx-post="${request.route_url('todos_activate_all_postponed')}"
                  hx-target="body"
                  style="display:inline-flex;align-items:center;gap:0.35rem;border-radius:9999px;padding:0.25rem 0.65rem;font-size:0.75rem;font-weight:500;background:#64748b;color:#fff;cursor:pointer;">
            ⏸ Paused
            <span style="display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.25);border-radius:9999px;padding:0 0.4rem;font-size:0.7rem;font-weight:700;min-width:1.2em;">${postponed_count}</span>
          </button>
        </tal:block>
        <tal:block tal:condition="postponed_count == 0">
          <span style="display:inline-flex;align-items:center;gap:0.35rem;border-radius:9999px;padding:0.25rem 0.65rem;font-size:0.75rem;font-weight:500;background:#e2e8f0;color:#94a3b8;">
            ⏸ Paused
            <span style="display:inline-flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.1);color:#94a3b8;border-radius:9999px;padding:0 0.4rem;font-size:0.7rem;font-weight:700;min-width:1.2em;">0</span>
          </span>
        </tal:block>
      </div>
      <a href="${request.route_url('list_todos_done')}"
         style="display:inline-flex;align-items:center;gap:0.35rem;border-radius:9999px;padding:0.25rem 0.65rem;font-size:0.75rem;font-weight:500;background:#e2e8f0;color:#475569;text-decoration:none;">
        ✓ Done
        <span style="display:inline-flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.1);border-radius:9999px;padding:0 0.4rem;font-size:0.7rem;font-weight:700;min-width:1.2em;">${done_count}</span>
      </a>
    </div>

    <!-- Todo list -->
    <div id="todo-list" class="-mx-4"
         data-done-url="${request.route_url('todos_done')}"
         data-postpone-url="${request.route_url('todos_postpone')}"
         data-undo-url="${request.route_url('todo_undo')}">

      <tal:block tal:repeat="group groups">
        <h3 tal:condition="group['items'] or group['name'] == '(untagged)'"
            class="text-xs font-semibold uppercase tracking-wide mt-4 mb-1"
            style="padding-left: ${group['depth'] * 1.25}rem; color: ${group['depth'] == 0 and '#64748b' or '#94a3b8'}">
          <tal:block tal:condition="group['depth'] > 0">└ </tal:block>${group['name']}
        </h3>
        <h3 tal:condition="not group['items'] and group['name'] != '(untagged)'"
            class="text-xs font-semibold uppercase tracking-wide text-slate-400 mt-3 mb-0.5"
            style="padding-left: ${group['depth'] * 1.25}rem">
          ${group['name']}
        </h3>

        <ul tal:condition="group['items']"
            class="border-l-2 border-slate-200 mb-1"
            style="margin-left: ${group['depth'] * 1.25}rem">
          <li tal:repeat="todo group['items']"
              id="todo-${todo.id}"
              class="todo-item flex items-center gap-2 py-2 px-3 bg-white mb-1 shadow-sm overflow-hidden">

            <input type="checkbox" class="todo-checkbox shrink-0"
                   data-id="${todo.id}" />

            <span class="flex-1 text-sm">${todo.text}</span>
          </li>
        </ul>
      </tal:block>

      <p tal:condition="not groups" class="text-slate-500 text-sm italic">No todos yet.</p>

    </div>
  </div>

</div>
