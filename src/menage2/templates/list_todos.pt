<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title-mobile">TODO</span>
  <div metal:fill-slot="title">TODO</div>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">

    <!-- Filter toggle bar -->
    <div class="d-flex gap-1 mb-2 align-items-center flex-wrap">
      <span class="text-muted small me-1">Show:</span>
      <tal:block tal:define="modes python:[('personal','My Tasks'),('delegated_out','Delegated out'),('delegated_in','Delegated in'),('all','All')]">
        <tal:block tal:repeat="mode modes">
          <a tal:define="mkey python:mode[0]; mlabel python:mode[1]"
             href="${request.route_url('list_todos')}?filter=${mkey}"
             tal:attributes="class python:'btn btn-sm rounded-pill ' + ('btn-dark' if filter_mode == mkey else 'btn-outline-secondary')">
            ${mlabel}
          </a>
        </tal:block>
      </tal:block>
    </div>

    <!-- Add / edit todo form (shared across views; rendered server-side) -->
    <tal:block tal:replace="structure form_html"/>

    <!-- Todo list (markup rendered server-side via _todo_groups.pt) -->
    <div id="todo-list"
         data-done-url="${request.route_url('todos_done')}"
         data-hold-url="${request.route_url('todos_hold')}"
         data-postpone-url="${request.route_url('todos_postpone')}"
         data-undo-url="${request.route_url('todo_undo')}">
      <tal:block tal:replace="structure groups_html"/>
    </div>
  </div>

</div>
