<div metal:use-macro="load: layout.pt">

  <div metal:fill-slot="title">Todos</div>

  <div metal:fill-slot="content" class="px-4 py-4 max-w-2xl">

    <!-- Add todo form -->
    <form hx-post="${request.route_url('add_todo')}"
          hx-target="body"
          class="mb-4 flex gap-2">
      <input type="text" name="text" autocomplete="off"
             placeholder="Add todo… #tag #category:sub"
             class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:outline-none focus:ring-2 focus:ring-cyan-400" />
      <button type="submit"
              class="rounded-lg bg-cyan-500 px-4 py-2 text-sm font-medium text-white shadow hover:bg-cyan-600">
        Add
      </button>
    </form>

    <!-- Activate postponed (id stable so OOB swaps can update it) -->
    <div id="postponed-section" class="mb-4">
      <button tal:condition="postponed_count > 0"
              hx-post="${request.route_url('todos_activate_all_postponed')}"
              hx-target="body"
              class="rounded-lg bg-slate-500 px-3 py-1.5 text-sm text-white shadow hover:bg-slate-600">
        Activate postponed (${postponed_count})
      </button>
    </div>

    <!-- Done link -->
    <div class="mb-4">
      <a href="${request.route_url('list_todos_done')}"
         class="text-sm text-slate-500 underline hover:text-slate-700">View done items</a>
    </div>

    <!-- Todo list -->
    <div id="todo-list" class="-mx-4"
         data-batch-done-url="${request.route_url('todos_batch_done')}"
         data-undo-url="${request.route_url('todo_undo')}">

      <tal:block tal:repeat="group groups">
        <h3 tal:condition="group['items'] or group['name'] == '(untagged)'"
            class="text-xs font-semibold uppercase tracking-wide mt-4 mb-1"
            style="padding-left: ${group['depth'] * 1.25}rem; color: ${group['depth'] == 0 and '#64748b' or '#94a3b8'}">
          <tal:block tal:condition="group['depth'] > 0">└ </tal:block>${group['name']}
        </h3>
        <h3 tal:condition="not group['items'] and group['name'] != '(untagged)'"
            class="text-xs font-semibold uppercase tracking-wide text-slate-400 mt-3 mb-0.5"
            style="padding-left: ${group['depth'] * 1.25}rem">
          ${group['name']}
        </h3>

        <ul tal:condition="group['items']"
            class="border-l-2 border-slate-200 mb-1"
            style="margin-left: ${group['depth'] * 1.25}rem">
          <li tal:repeat="todo group['items']"
              id="todo-${todo.id}"
              class="todo-item flex items-center gap-2 py-2 px-3 bg-white mb-1 shadow-sm overflow-hidden"
              data-done-url="${request.route_url('todo_done', id=todo.id)}"
              data-postpone-url="${request.route_url('todo_postpone', id=todo.id)}">

            <input type="checkbox" class="todo-checkbox shrink-0"
                   data-id="${todo.id}" />

            <span class="flex-1 text-sm">${todo.text}</span>
          </li>
        </ul>
      </tal:block>

      <p tal:condition="not groups" class="text-slate-500 text-sm italic">No todos yet.</p>

    </div>
  </div>

</div>
