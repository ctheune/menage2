<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title">Die Rezepte</span>

  <span metal:fill-slot="actions">
    <input type="button"
        value="Neues Rezept"
        hx-put="${request.route_url('add_recipe')}"
        hx-target="body"
        class="btn btn-sm btn-outline-secondary" />
  </span>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">
    <p tal:condition="not recipes" class="text-muted fst-italic">
      Noch keine Rezepte vorhanden.
      <input type="button"
          value="Erstes Rezept anlegen"
          hx-put="${request.route_url('add_recipe')}"
          hx-target="body"
          class="btn btn-sm btn-outline-secondary ms-2" />
    </p>
    <div class="row row-cols-auto g-3">
      <div class="col" tal:repeat="recipe recipes">
        <div class="card h-100" style="width:17rem">
          <div class="card-body">
            <a href="${request.route_url('edit_recipe', id=recipe.id)}" class="text-decoration-none text-reset">
              <h6 class="card-title">${recipe.id} – ${recipe.title}</h6>
              <p class="card-text text-muted small">
                <span tal:repeat="recipe_ingredient recipe.ingredients">
                  <span tal:omit-tag="" tal:condition="recipe_ingredient.amount">${recipe_ingredient.amount}&#8239;</span><span tal:omit-tag="" tal:condition="recipe_ingredient.unit">${recipe_ingredient.unit}&#8239;</span>${recipe_ingredient.ingredient.description}${", " if not repeat['recipe_ingredient'].end else ""}
                </span>
              </p>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
