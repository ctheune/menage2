<!DOCTYPE html>
<div metal:use-macro="load: layout_fullscreen.pt">

  <metal:block fill-slot="header-after">
      <title>Menage – Dashboard</title>
  </metal:block>

  <div metal:fill-slot="content" class="container-fluid py-3">

    <div class="row g-3">

      <!-- Left column -->
      <div class="col-md-6">
        <div class="card h-100"
            hx-get="${dashboard_recipes_url}"
            hx-trigger="load, every 10m">
            ...
        </div>
      </div>

      <!-- Right column -->
      <div class="col-md-6 d-flex flex-column gap-3">

        <div class="card" hx-get="${request.route_url('timers')}" hx-trigger="load">
          ...
        </div>

        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Richtung Stadt</h5>
            <div hx-get="${dashboard_pt_departures_url}"
                 hx-trigger="load, every 10s">
              ...
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-body">
            <h5 class="card-title">Zum Bahnhof</h5>
            <div hx-get="${dashboard_pt_hbf_url}"
                 hx-trigger="load, every 10s">
              ...
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
