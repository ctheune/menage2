<!DOCTYPE html>
<div metal:use-macro="load: layout_fullscreen.pt">

  <metal:block fill-slot="header-after">
      <title>Menage – Dashboard</title>
  </metal:block>

  <div metal:fill-slot="content" class="container-fluid py-3">

    <div class="row g-3">

      <!-- Left column -->
      <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header">Wochenplan</div>
            <div
                hx-get="${dashboard_recipes_url}"
                hx-trigger="load, every 10m">
                ...
            </div>
        </div>
      </div>

      <!-- Right column -->
      <div class="col-md-6 d-flex flex-column gap-3">
        <div class="card">
          <div class="card-header">Timers</div>
          <div hx-get="${dashboard_timers_url}" hx-trigger="load">
          ...
          </div>
        </div>

        <div class="card">
          <div class="card-header">Öffis in die Stadt</div>
          <div class="card-body">
            <div hx-get="${dashboard_pt_departures_url}"
                 hx-trigger="load, every 10s">
              ...
            </div>
          </div>
        </div>

        <div class="card">
          <div class="card-header">Öffis zum Bahnhof</div>
          <div class="card-body">
            <div hx-get="${dashboard_pt_hbf_url}"
                 hx-trigger="load, every 10s">
              ...
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>
