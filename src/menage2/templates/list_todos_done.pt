<div metal:use-macro="load: layout.pt">

  <div metal:fill-slot="title">Done Todos</div>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">

    <div class="mb-3">
      <a href="${request.route_url('list_todos')}" class="link-secondary">← Back to Todos</a>
    </div>

    <div id="done-list"
         data-batch-activate-url="${request.route_url('todos_activate_batch')}">

      <tal:block tal:condition="todos">
        <ul class="list-unstyled">
          <li tal:repeat="todo todos"
              id="todo-${todo.id}"
              class="todo-item mb-1 shadow-sm">

            <div class="todo-content d-flex align-items-center py-2 px-3 bg-white rounded gap-3">
              <input type="checkbox" class="form-check-input todo-checkbox flex-shrink-0" data-id="${todo.id}" />

              <span class="flex-grow-1 text-truncate small">
                <span>${todo.text}</span>
                <span tal:condition="todo.note"
                      class="d-block text-muted" style="font-size:0.7rem">${todo.note}</span>
              </span>

              <a tal:condition="todo.protocol_run_id"
                 tal:attributes="href python:request.route_url('show_protocol_run', id=todo.protocol_run_id)"
                 class="todo-protocol-link flex-shrink-0 small"
                 title="Open protocol run">
                <i class="bi bi-clipboard-check"></i>
              </a>

              <span tal:repeat="tag python:sorted(todo.tags)"
                    class="badge bg-secondary rounded-pill flex-shrink-0">
                #${tag}
              </span>

              <span tal:condition="todo.done_at"
                    class="flex-shrink-0 text-muted"
                    style="font-size:0.7rem"
                    title="${absolute_with_weekday(todo.done_at)}">
                ${humanize_ago(todo.done_at)}
              </span>

              <button hx-post="${request.route_url('todos_activate_batch')}"
                      hx-vals='{"todo_ids": "${todo.id}"}'
                      hx-target="#done-list"
                      hx-swap="innerHTML"
                      class="btn btn-link btn-sm p-0 text-muted flex-shrink-0">
                ↩
              </button>
            </div>
          </li>
        </ul>
      </tal:block>

      <p tal:condition="not todos" class="text-muted fst-italic">No completed todos.</p>

    </div>
  </div>

</div>
