<div metal:use-macro="load: layout.pt">
  <div metal:fill-slot="title">Done Todos</div>

  <div metal:fill-slot="content" class="container-fluid px-3 pt-3">
    <!-- Filter toggle bar -->
    <div class="d-flex gap-1 mb-2 align-items-center flex-wrap">
      <tal:block
        tal:define="modes python:[('personal','My Tasks'),('delegated_out','Delegated out'),('delegated_in','Delegated in'),('all','All')]"
      >
        <tal:block tal:repeat="mode modes">
          <a
            tal:define="mkey python:mode[0]; mlabel python:mode[1]"
            href="${request.route_url('list_todos_done')}?filter=${mkey}"
            tal:attributes="class python:'btn btn-sm rounded-pill ' + ('btn-dark' if filter_mode == mkey else 'btn-outline-secondary')"
          >
            ${mlabel}
          </a>
        </tal:block>
      </tal:block>
    </div>

    <div
      id="done-list"
      data-batch-activate-url="${request.route_url('todos_activate_batch')}"
      _="on keydown[key is 'r'] from body
           if the tagName of target is 'INPUT' or the tagName of target is 'TEXTAREA' or the isContentEditable of target exit end
           if no <input.todo-checkbox:checked/> in me exit end
           trigger reactivateSelected on the first <.reactivate-trigger/> in me"
    >
      <button
        class="reactivate-trigger d-none"
        type="button"
        hx-post="${request.route_url('todos_activate_batch')}"
        hx-trigger="reactivateSelected"
        hx-include="#done-list .todo-checkbox:checked"
        hx-target="#done-list"
        hx-swap="innerHTML"
        aria-hidden="true"
        tabindex="-1"
      ></button>
      <tal:block tal:condition="todos">
        <ul class="list-unstyled">
          <li
            tal:repeat="todo todos"
            id="todo-${todo.id}"
            class="todo-item mb-1 shadow-sm"
          >
            <div
              class="todo-content d-flex align-items-center py-2 px-3 bg-white rounded gap-3"
            >
              <input
                type="checkbox"
                name="todo_ids"
                value="${todo.id}"
                class="form-check-input todo-checkbox flex-shrink-0"
                data-id="${todo.id}"
              />

              <span class="flex-grow-1 text-truncate small">
                <span>${todo.text}</span>
                <span
                  tal:condition="todo.note"
                  class="d-block text-muted"
                  style="font-size: 0.7rem"
                  >${todo.note}</span
                >
              </span>

              <a
                tal:condition="todo.protocol_run_id"
                class="todo-protocol-link flex-shrink-0 small"
              >
                <i class="bi bi-clipboard-check"></i>
              </a>

              <span
                tal:repeat="tag python:sorted(todo.tags)"
                class="badge bg-secondary rounded-pill flex-shrink-0"
              >
                #${tag}
              </span>

              <span
                tal:condition="todo.done_at"
                class="flex-shrink-0 text-muted"
                style="font-size: 0.7rem"
                title="${absolute_with_weekday(todo.done_at)}"
              >
                ${humanize_ago(todo.done_at)}
              </span>

              <button
                hx-post="${request.route_url('todos_activate_batch')}"
                hx-vals='{"todo_ids": "${todo.id}"}'
                hx-target="#done-list"
                hx-swap="innerHTML"
                class="btn btn-link btn-sm p-0 text-muted flex-shrink-0"
              >
                ↩
              </button>
            </div>
          </li>
        </ul>
      </tal:block>

      <p tal:condition="not todos" class="text-muted fst-italic">
        No completed todos.
      </p>
    </div>
  </div>
</div>
