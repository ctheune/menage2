<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title-mobile">On Hold</span>
  <div metal:fill-slot="title">On Hold</div>

  <span metal:fill-slot="actions">
    <form tal:condition="todos"
          method="post" action="${request.route_url('todos_activate_all_on_hold')}"
          class="d-inline m-0">
      <button type="submit" class="btn btn-sm btn-dark text-nowrap">
        <i class="bi bi-arrow-clockwise"></i> Activate all
      </button>
    </form>
  </span>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">

    <!-- Filter toggle bar -->
    <div class="d-flex gap-1 mb-2 align-items-center flex-wrap">
      <span class="text-muted small me-1">Show:</span>
      <tal:block tal:define="modes python:[('personal','My Tasks'),('delegated_out','Delegated out'),('delegated_in','Delegated in'),('all','All')]">
        <tal:block tal:repeat="mode modes">
          <a tal:define="mkey python:mode[0]; mlabel python:mode[1]"
             href="${request.route_url('list_todos_hold')}?filter=${mkey}"
             tal:attributes="class python:'btn btn-sm rounded-pill ' + ('btn-dark' if filter_mode == mkey else 'btn-outline-secondary')">
            ${mlabel}
          </a>
        </tal:block>
      </tal:block>
    </div>

    <div id="hold-list"
         data-batch-activate-url="${request.route_url('todos_activate_batch')}">

      <tal:block tal:condition="todos">
        <ul class="list-unstyled">
          <li tal:repeat="todo todos"
              id="todo-${todo.id}"
              class="todo-item mb-1 shadow-sm">

            <div class="todo-content d-flex align-items-center py-2 px-3 bg-white rounded gap-3">
              <input type="checkbox" class="form-check-input todo-checkbox flex-shrink-0" data-id="${todo.id}" />

              <span class="flex-grow-1 text-truncate small">
                <span>${todo.text}</span>
                <span tal:condition="todo.note"
                      class="d-block text-muted" style="font-size:0.7rem">${todo.note}</span>
              </span>

              <span tal:repeat="tag python:sorted(todo.tags)"
                    class="badge bg-secondary rounded-pill flex-shrink-0">
                #${tag}
              </span>

              <span tal:condition="todo.assignees"
                    class="flex-shrink-0 small text-muted">
                <tal:block tal:repeat="a python:sorted(todo.assignees)">@${a} </tal:block>
              </span>

              <button hx-post="${request.route_url('todos_activate_batch')}"
                      hx-vals='{"todo_ids": "${todo.id}"}'
                      hx-target="#hold-list"
                      hx-swap="innerHTML"
                      class="btn btn-link btn-sm p-0 text-muted flex-shrink-0"
                      title="Activate">
                <i class="bi bi-play-fill"></i>
              </button>
            </div>
          </li>
        </ul>
      </tal:block>

      <p tal:condition="not todos" class="text-muted fst-italic">Nothing on hold.</p>

    </div>
  </div>

</div>
