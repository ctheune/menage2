<tal:block tal:condition="groups">
  <div style="display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;">
    <button onclick="setAllGroups(true)"
            style="font-size:0.7rem;color:#64748b;background:none;border:none;cursor:pointer;padding:0;">
      ⊞ expand all
    </button>
    <span style="color:#cbd5e1;font-size:0.7rem;">·</span>
    <button onclick="setAllGroups(false)"
            style="font-size:0.7rem;color:#64748b;background:none;border:none;cursor:pointer;padding:0;">
      ⊟ collapse all
    </button>
  </div>
</tal:block>

<tal:block tal:repeat="group groups">
  <div class="tag-group-header"
       data-tag="${group['full_tag']}"
       data-parent-tag="${group['parent_tag']}"
       data-open="true"
       style="padding-left:${group['depth'] * 1.25}rem">
    <span class="tag-toggle">▾</span>
    <tal:block tal:condition="group['depth'] > 0 and group['name'] != '(untagged)'">└ </tal:block>${group['name']}
    <span class="tag-count-badge">${group['total_count']}</span>
  </div>

  <ul tal:condition="group['items']"
      data-parent-tag="${group['full_tag']}"
      class="border-l-2 border-slate-200 mb-1"
      style="margin-left:${group['depth'] * 1.25}rem">
    <li tal:repeat="todo group['items']"
        id="todo-${todo.id}"
        class="todo-item flex items-center gap-2 py-2 px-3 bg-white mb-1 shadow-sm overflow-hidden"
        data-todo-text="${todo.text}"
        data-todo-tags="${python:','.join(sorted(todo.tags))}"
        data-edit-url="${request.route_url('edit_todo', id=todo.id)}">

      <input type="checkbox" class="todo-checkbox shrink-0"
             data-id="${todo.id}" />

      <span class="flex-1min-w-0" style="font-size:0.875rem;display:flex;flex-direction:column;gap:0.1rem;">
        <span>${todo.text}</span>
        <span tal:condition="todo.note"
              style="font-size:0.7rem;color:#94a3b8;">${todo.note}</span>
      </span>

      <button type="button" class="todo-edit-btn shrink-0" title="Edit"
              style="background:none;border:none;cursor:pointer;color:#94a3b8;font-size:0.85rem;padding:0 0.15rem;line-height:1;">✎</button>
    </li>
  </ul>
</tal:block>

<p tal:condition="not groups" class="text-slate-500 text-sm italic">No todos yet.</p>
