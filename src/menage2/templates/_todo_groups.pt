<tal:block tal:condition="groups">
  <div class="d-flex gap-2 align-items-center mb-2">
    <button onclick="setAllGroups(true)"
            class="btn btn-link btn-sm p-0 text-secondary">
      <i class="bi bi-arrows-expand"></i> expand all
    </button>
    <span class="text-secondary">·</span>
    <button onclick="setAllGroups(false)"
            class="btn btn-link btn-sm p-0 text-secondary">
      <i class="bi bi-arrows-collapse"></i> collapse all
    </button>
  </div>
</tal:block>

<tal:block tal:repeat="group groups">
  <div class="tag-group-header"
       data-tag="${group['full_tag']}"
       data-parent-tag="${group['parent_tag']}"
       data-open="true"
       style="padding-left:${group['depth'] * 1.25}rem">
    <span class="tag-toggle">▾</span>
    <tal:block tal:condition="group['depth'] > 0 and group['name'] != '(untagged)'">└ </tal:block>${group['name']}
    <span class="tag-count-badge">${group['total_count']}</span>
  </div>

  <ul tal:condition="group['items']"
      data-parent-tag="${group['full_tag']}"
      class="border-start border-2 mb-1 list-unstyled"
      style="margin-left:${group['depth'] * 1.25}rem">
    <li tal:repeat="todo group['items']"
        id="todo-${todo.id}"
        class="todo-item mb-1 shadow-sm"
        data-todo-text="${todo.text}"
        data-todo-tags="${python:','.join(sorted(todo.tags))}"
        data-edit-url="${request.route_url('edit_todo', id=todo.id)}">

      <div class="todo-content d-flex align-items-center gap-2 py-2 px-3 bg-white">
        <input type="checkbox" class="form-check-input todo-checkbox flex-shrink-0"
               data-id="${todo.id}" />

        <span class="flex-grow-1 text-truncate small">
          <span>${todo.text}</span>
          <span tal:condition="todo.note"
                class="d-block text-muted" style="font-size:0.7rem">${todo.note}</span>
        </span>

        <button type="button" class="todo-edit-btn flex-shrink-0 btn btn-link btn-sm p-0 text-muted" title="Edit">✎</button>
      </div>
    </li>
  </ul>
</tal:block>

<p tal:condition="not groups" class="text-muted fst-italic">No todos yet.</p>
