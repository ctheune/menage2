<div class="dropdown-menu show position-absolute shadow suggest-dropdown" tal:condition="search">
  <ul class="list-unstyled mb-0">
    <li tal:condition="not exact_match" class="dropdown-item border-bottom pb-2">
      <label class="fst-italic">
        <input type="radio" class="me-2" value="new" name="suggestion-${radio_uuid}"
            _="on change
                get first .suggest-id in the closest parent <td/>
                then set its value to 'new'
                then get the next .suggest-input from it
                then set its value to '${search}'
                then remove the closest .suggest-dropdown" />
                Neue Zutat: &quot;${search}&quot;
      </label>
    </li>
    <li tal:repeat="ingredient ingredients" class="dropdown-item">
      <label>
        <input type="radio" class="me-2"
          name="suggestion-${radio_uuid}"
          value="${ingredient.id}"
          _="on change
                get first .suggest-id in the closest parent <td/>
                then set its value to '${ingredient.id}'
                then get the next .suggest-input from it
                then set its value to '${ingredient.description}'
                then remove the closest .suggest-dropdown"/>${ingredient.description}
      </label>
    </li>
  </ul>
</div>
