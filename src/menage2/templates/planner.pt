<div metal:use-macro="load: layout.pt">
  <span metal:fill-slot="title">
    Wochenplaner vom ${format.date(week.first.day, "long")} – ${format.date(week.last.day, "long")}
  </span>

  <span metal:fill-slot="actions">
    <a href="#" hx-post="${request.route_url('send_to_shopping_list', id=week.id)}"
       hx-target="body"
       class="btn btn-sm btn-outline-secondary">Auf die Einkaufsliste</a>
    <input type="submit" id="submit" form="edit-week" value="Speichern" class="btn btn-sm btn-secondary"/>
  </span>

  <div metal:fill-slot="content" class="container-fluid px-3 py-3">
    <div class="text-end mb-2" hx-disinherit="*">
      <a href="#" hx-put="${request.route_url('add_day', position='before', id=week.id)}"
         hx-target="body"
         title="Add a day to the beginning of the week" class="btn btn-sm btn-outline-secondary">➕</a>
    </div>

    <form hx-post="${request.route_url('edit_week', id=week.id)}" hx-trigger="change" hx-select="#edit-week" hx-indicator="#submit" id="edit-week">
      <div tal:repeat="day week.days" class="card mb-3">
        <div class="card-header">${format.date(day.day, "full")}</div>
        <div class="card-body">
          <div class="float-end d-flex gap-2" hx-disinherit="*">
            <a href="#" hx-delete="${request.route_url('delete_day', day=day.id)}"
               hx-target="body"
               hx-confirm="Delete this day?"
               tal:condition="repeat.day.start or repeat.day.end"
               title="Remove this day from the plan">🗑️</a>
          </div>
          <div class="d-flex flex-wrap gap-4">
            <div>
              <h6>Rezept aus dem Rezeptbuch</h6>
              <div class="d-flex align-items-center mb-3">
                <select name="dinner" class="form-select" style="width:16rem">
                  <option value="none" tal:attributes="selected True if day.dinner is None else None">Kein Rezept</option>
                  <option tal:repeat="recipe recipes"
                    tal:attributes="value recipe.id; selected True if (day.dinner and recipe.id == day.dinner.id) else None">
                    ${recipe.id} – ${recipe.title}
                  </option>
                </select>
                <span hx-disinherit="*">
                  <a href="#" hx-post="${request.route_url('toggle_day_shopping', day=day.id)}"
                     hx-target="body"
                     tal:attributes="title python:'Von Einkaufsliste ausschließen' if not day.exclude_from_shopping else 'Auf Einkaufsliste aufnehmen'"
                     class="ms-3 fs-5 text-decoration-none"
                     style="${'opacity:0.3' if day.exclude_from_shopping else ''}">🛒</a>
                </span>
              </div>
            </div>
            <div>
              <h6>Vorschläge</h6>
              <ul class="list-unstyled fw-light small" hx-disinherit="*">
                <li tal:repeat="suggestion day.suggestions()">
                  <a class="link-secondary" hx-post="${request.route_url('set_dinner', day=day.day.isoformat(), recipe=suggestion.id)}" hx-target="body">
                    ${suggestion.id} – ${suggestion.title}
                  </a>
                  <a href="${request.route_url('edit_recipe', id=suggestion.id)}"> ✏️ </a>
                </li>
              </ul>
            </div>
            <div>
              <h6>Freies Rezept</h6>
              <textarea name="dinner_freestyle" class="form-control" style="width:16rem">${day.dinner_freestyle}</textarea>
            </div>
            <div>
              <h6>Notizen zum Tag</h6>
              <textarea name="note" class="form-control" style="width:16rem">${day.note}</textarea>
            </div>
          </div>
        </div>
      </div>
    </form>

    <div class="text-end mb-2" hx-disinherit="*">
      <a href="#" hx-put="${request.route_url('add_day', position='after', id=week.id)}"
         hx-target="body"
         title="Add a day to the end of the week" class="btn btn-sm btn-outline-secondary">➕</a>
    </div>

  </div>
</div>
