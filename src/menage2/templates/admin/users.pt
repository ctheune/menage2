<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Users</span>
  <div metal:fill-slot="title">User Management</div>

  <div metal:fill-slot="content" class="container py-4">

    <div class="mb-3">
      <a href="${request.route_url('admin_user_new')}" class="btn btn-sm btn-dark">
        <i class="bi bi-plus-lg"></i> Add User
      </a>
    </div>

    <div class="card">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Username</th>
              <th>Email</th>
              <th>Role</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <tr tal:repeat="user users">
              <td>${user.real_name}</td>
              <td class="font-monospace text-muted small">${user.username}</td>
              <td class="text-muted">${user.email}</td>
              <td>
                <span tal:condition="user.is_admin" class="badge bg-primary">Admin</span>
                <span tal:condition="not user.is_admin" class="text-muted small">User</span>
              </td>
              <td>
                <span tal:condition="user.is_active" class="badge bg-success">Active</span>
                <span tal:condition="not user.is_active" class="badge bg-secondary">Inactive</span>
              </td>
              <td class="d-flex gap-2">
                <a href="${request.route_url('admin_user_edit', id=user.id)}" class="link-secondary small">Edit</a>
                <tal:block tal:condition="user.id != request.identity.id">
                  <tal:block tal:condition="user.is_active">
                    <form method="post" action="${request.route_url('admin_user_deactivate', id=user.id)}"
                          class="d-inline"
                          onsubmit="return confirm('Deactivate ${user.username}?')">
                      <button type="submit" class="btn btn-link btn-sm p-0 text-warning">Deactivate</button>
                    </form>
                  </tal:block>
                  <form method="post" action="${request.route_url('admin_user_delete', id=user.id)}"
                        class="d-inline"
                        onsubmit="return confirm('Delete ${user.username}? This cannot be undone.')">
                    <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Delete</button>
                  </form>
                </tal:block>
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-4">
      <a href="${request.route_url('admin_dashboard_token')}" class="link-secondary">
        Dashboard Secret URL →
      </a>
    </div>

  </div>
</div>
