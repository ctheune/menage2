<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">${'Edit User' if user else 'New User'}</span>
  <div metal:fill-slot="title">${'Edit User: ' + user.username if user else 'Add User'}</div>

  <div metal:fill-slot="content" class="px-4 py-8 max-w-sm mx-auto">

    <form method="post" action="${action}" class="space-y-4">

      <tal:block tal:condition="user is None">
        <div>
          <label for="username" class="block text-sm font-medium text-slate-700 mb-1">Username</label>
          <input type="text" id="username" name="username" required autofocus autocomplete="off"
                 class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
          <tal:block tal:condition="'username' in errors">
            <p class="text-red-600 text-xs mt-1">${errors['username']}</p>
          </tal:block>
        </div>
      </tal:block>

      <div>
        <label for="real_name" class="block text-sm font-medium text-slate-700 mb-1">Full Name</label>
        <input type="text" id="real_name" name="real_name" required
               value="${user.real_name if user else ''}"
               class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
        <tal:block tal:condition="'real_name' in errors">
          <p class="text-red-600 text-xs mt-1">${errors['real_name']}</p>
        </tal:block>
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
        <input type="email" id="email" name="email" required autocomplete="off"
               value="${user.email if user else ''}"
               class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
        <tal:block tal:condition="'email' in errors">
          <p class="text-red-600 text-xs mt-1">${errors['email']}</p>
        </tal:block>
      </div>

      <div>
        <label for="password" class="block text-sm font-medium text-slate-700 mb-1">
          Password <span tal:condition="user is not None" class="text-slate-400 font-normal">(leave blank to keep unchanged)</span>
        </label>
        <input type="password" id="password" name="password" autocomplete="new-password"
               class="w-full border border-slate-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-slate-500" />
      </div>

      <div class="flex items-center gap-4">
        <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
          <input type="checkbox" name="is_admin" value="1"
                 checked="${'checked' if (user and user.is_admin) else None}" />
          Administrator
        </label>
        <tal:block tal:condition="user is not None">
          <label class="flex items-center gap-2 text-sm text-slate-700 cursor-pointer">
            <input type="checkbox" name="is_active" value="1"
                   checked="${'checked' if user.is_active else None}" />
            Active
          </label>
        </tal:block>
      </div>
      <tal:block tal:condition="'is_admin' in errors">
        <p class="text-red-600 text-xs">${errors['is_admin']}</p>
      </tal:block>

      <div class="flex gap-3">
        <button type="submit"
                class="bg-slate-700 hover:bg-slate-800 text-white font-medium py-2 px-4 rounded text-sm">
          ${('Save Changes' if user else 'Create User')}
        </button>
        <a href="${request.route_url('admin_users')}"
           class="text-sm text-slate-600 hover:underline self-center">Cancel</a>
      </div>
    </form>

  </div>
</div>
