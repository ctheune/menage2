<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">${'Edit User' if user else 'New User'}</span>
  <div metal:fill-slot="title">${'Edit User: ' + user.username if user else 'Add User'}</div>

  <div metal:fill-slot="content" class="container py-3">
    <div class="row justify-content-center">
      <div class="col-12 col-sm-8 col-md-5 col-lg-4">
        <div class="card">
          <div class="card-body">
        <form method="post" action="${action}">

          <tal:block tal:condition="user is None">
            <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text" id="username" name="username" required autofocus autocomplete="off"
                     class="form-control" />
              <tal:block tal:condition="'username' in errors">
                <p class="text-danger small mt-1">${errors['username']}</p>
              </tal:block>
            </div>
          </tal:block>

          <div class="mb-3">
            <label for="real_name" class="form-label">Full Name</label>
            <input type="text" id="real_name" name="real_name" required
                   value="${user.real_name if user else ''}" class="form-control" />
            <tal:block tal:condition="'real_name' in errors">
              <p class="text-danger small mt-1">${errors['real_name']}</p>
            </tal:block>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email</label>
            <input type="email" id="email" name="email" required autocomplete="off"
                   value="${user.email if user else ''}" class="form-control" />
            <tal:block tal:condition="'email' in errors">
              <p class="text-danger small mt-1">${errors['email']}</p>
            </tal:block>
          </div>

          <div class="mb-3">
            <label for="password" class="form-label">
              Password <span tal:condition="user is not None" class="text-muted fw-normal">(leave blank to keep unchanged)</span>
            </label>
            <input type="password" id="password" name="password" autocomplete="new-password"
                   class="form-control" />
          </div>

          <div class="mb-3 d-flex gap-4">
            <div class="form-check">
              <input type="checkbox" class="form-check-input" name="is_admin" value="1" id="is_admin"
                     checked="${'checked' if (user and user.is_admin) else None}" />
              <label class="form-check-label" for="is_admin">Administrator</label>
            </div>
            <tal:block tal:condition="user is not None">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="is_active" value="1" id="is_active"
                       checked="${'checked' if user.is_active else None}" />
                <label class="form-check-label" for="is_active">Active</label>
              </div>
            </tal:block>
          </div>
          <tal:block tal:condition="'is_admin' in errors">
            <p class="text-danger small">${errors['is_admin']}</p>
          </tal:block>

          <div class="d-flex gap-3 align-items-center">
            <button type="submit" class="btn btn-dark">
              ${('Save Changes' if user else 'Create User')}
            </button>
            <a href="${request.route_url('admin_users')}" class="link-secondary">Cancel</a>
          </div>
        </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
