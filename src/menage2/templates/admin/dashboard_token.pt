<div metal:use-macro="load: ../layout.pt">
  <span metal:fill-slot="title-mobile">Dashboard URL</span>
  <div metal:fill-slot="title">Dashboard Secret URL</div>

  <div metal:fill-slot="content" class="container py-4">
    <div class="row justify-content-center">
      <div class="col-12 col-md-8 col-lg-6">

        <div class="card mb-3">
          <div class="card-body">
            <p class="text-muted">
              The kitchen dashboard is accessible via a secret URL. Only share this URL with devices
              that should display the dashboard. Resetting it will invalidate any existing bookmarks.
            </p>

            <tal:block tal:condition="token is not None">
              <label class="form-label small text-muted">Current Dashboard URL</label>
              <div class="input-group mb-3">
                <input type="text" readonly
                       value="${dashboard_url}"
                       class="form-control form-control-sm font-monospace"
                       onclick="this.select()" />
                <button type="button"
                        class="btn btn-sm btn-outline-secondary"
                        onclick="navigator.clipboard.writeText('${dashboard_url}')">
                  Copy
                </button>
              </div>
            </tal:block>

            <div tal:condition="token is None" class="alert alert-warning">
              No dashboard URL has been generated yet.
            </div>

            <form method="post" action="${request.route_url('admin_dashboard_token')}"
                  onsubmit="return ${('confirm(\'Reset the dashboard URL? All existing bookmarks will stop working.\')') if token else 'true'}">
              <button type="submit" class="btn btn-dark btn-sm">
                ${('Reset URL' if token else 'Generate URL')}
              </button>
            </form>
          </div>
        </div>

        <a href="${request.route_url('admin_users')}" class="link-secondary">← Back to users</a>

      </div>
    </div>
  </div>
</div>
