<div metal:use-macro="load: layout.pt">

  <span metal:fill-slot="title">
    <a href="${request.route_url('edit_recipe', id=previous_recipe.id) if previous_recipe else None}"
       class="btn btn-sm btn-outline-secondary me-2">←</a>
    Rezept #${recipe.id}
    <a href="${request.route_url('edit_recipe', id=next_recipe.id) if next_recipe else None}"
       class="btn btn-sm btn-outline-secondary ms-2">→</a>
  </span>

  <div metal:fill-slot="content" class="p-3">

    <form hx-post="${request.route_url('edit_recipe', id=recipe.id)}"
          autocomplete="off"
          hx-select="#edit-recipe"
          hx-trigger="submit"
          id="edit-recipe">

      <div class="d-flex flex-wrap gap-4">
        <div>
          <h5 class="mt-3">Titel</h5>
          <input type="text" name="${field_name('title')}" id="edit-recipe-title" value="${recipe.title}"
                 class="form-control" style="width:36rem" />

          <h5 class="mt-3">Status</h5>
          <div class="form-check">
            <input type="checkbox" name="${field_name('active')}" value="true"
                   class="form-check-input"
                   tal:attributes="checked recipe.active or None" id="active-check">
            <label class="form-check-label" for="active-check">Aktiv</label>
          </div>

          <div class="d-flex gap-4 mt-3">
            <div>
              <h5>Quelle</h5>
              <input type="text" class="form-control" style="width:20rem" name="${field_name('source')}" value="${recipe.source}" />
            </div>
            <div>
              <h5>Quelle (Web)</h5>
              <input type="text" class="form-control" style="width:20rem" name="${field_name('source_url')}" value="${recipe.source_url}" />
            </div>
          </div>

          <h5 class="mt-3">Rezept</h5>
          <textarea class="form-control" style="width:36rem;height:20rem" name="${field_name('recipe')}">${recipe.recipe}</textarea>

          <h5 class="mt-3">Notizen</h5>
          <textarea class="form-control" style="width:36rem;height:10rem" name="${field_name('note')}">${recipe.note}</textarea>
        </div>

        <div>
          <h5 class="mt-3">Wochentage</h5>
          <input type="hidden" name="${field_name('__start__')}" value="weekdays:sequence"/>
          <div class="mb-2">
            <input type="button" class="btn btn-sm btn-outline-secondary me-1"
                    _="on click
                          repeat in (<input[name]/> in next <ul/>)
                            set its checked to true
                          end
                       " value="Alle">
            <input type="button"
                    _="on click
                        repeat in (<input[name]/> in next <ul/>)
                          set its checked to false
                        end"
                  class="btn btn-sm btn-outline-secondary" value="Keine"/>
          </div>
          <ul class="list-unstyled">
            <li tal:repeat="weekday weekdays">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="${field_name('weekdays')}" value="${weekday.value}"
                      tal:attributes="checked weekday in recipe.enum_weekdays or None"
                      id="wd-${weekday.value}" />
                <label class="form-check-label" for="wd-${weekday.value}">${format.locale.days['format']['wide'][weekday.value-1]}</label>
              </div>
            </li>
          </ul>
          <input type="hidden" name="${field_name('__end__')}" value="weekdays:sequence"/>

          <h5 class="mt-3">Häufigkeit</h5>
          <div class="input-group" style="width:12rem">
            <span class="input-group-text">Alle</span>
            <input type="text"
              name="${field_name('frequency')}" value="${recipe.schedule.frequency}"
              class="form-control" />
            <span class="input-group-text">Tage</span>
          </div>
        </div>

        <div>
          <h5 class="mt-3">Saison</h5>
          <input type="hidden" name="${field_name('__start__')}" value="seasons:sequence"/>
          <div class="mb-2">
            <input type="button" class="btn btn-sm btn-outline-secondary me-1"
                    _="on click
                          repeat in(<input[name]/> in next <ul/>)
                           set its checked to true
                          end
                       " value="Alle">
            <input type="button"
                    _="on click
                        repeat in(<input[name]/> in next <ul/>)
                         set its checked to false
                        end"
                  class="btn btn-sm btn-outline-secondary" value="Keine"/>
          </div>
          <ul class="list-unstyled">
            <li tal:repeat="month months">
              <div class="form-check">
                <input type="checkbox" class="form-check-input" name="${field_name('seasons')}"
                  value="${month.value}"
                  tal:attributes="checked month in recipe.enum_seasons or None"
                  id="mo-${month.value}" />
                <label class="form-check-label" for="mo-${month.value}">${format.locale.months['format']['wide'][month.value]}</label>
              </div>
            </li>
          </ul>
          <input type="hidden" name="${field_name('__end__')}" value="seasons:sequence"/>
        </div>

        <div>
          <ul class="list-unstyled mt-4">
            <li class="mb-2">
              <input type="submit" value="Speichern" class="btn btn-secondary"/>
            </li>
            <li hx-disinherit="hx-select" class="mb-2">
              <a href="${request.route_url('list_recipes')}" class="btn btn-outline-secondary">Abbrechen</a>
            </li>
          </ul>
        </div>
      </div>

      <h5 class="mt-3">Zutaten
        <button type="button" class="btn btn-link btn-sm text-success"
          _="on click get the next .template
            then put its outerHTML after the last .table-row in the next .ingredient-table
            then get the last .table-row in the next .ingredient-table
            then set newRow to it
            then for input in <[name]/> in it
                set sequence to the next .next-sequence
                then set its @name to it's @name + ':' + sequence's value
                then increment the sequence's value
                end
            then remove .template from the newRow
            then remove .d-none from the newRow
            "><i class="bi bi-plus-circle"></i></button>
      </h5>

      <table class="table table-sm ingredient-table mb-5">
        <thead>
          <tr>
            <th class="text-end" style="width:6rem">Menge</th>
            <th style="width:6rem">Einheit</th>
            <th style="width:24rem">Zutat</th>
            <th></th>
          </tr>
        </thead>
        <tbody class="table-row-group">
          <input type="hidden" name="${field_name('__start__')}" value="ingredients:sequence" />
          <tr class="table-row" tal:repeat="used recipe.ingredients">
            <input type="hidden" name="${field_name('__start__')}" value="mapping" />
            <td class="text-end">
              <input type="text" name="${field_name('amount')}" value="${used.amount}"
                     class="form-control form-control-sm text-end" style="width:5rem" />
            </td>
            <td>
              <input type="text" name="${field_name('unit')}" value="${used.unit}"
                     class="form-control form-control-sm" style="width:5rem" />
            </td>
            <td hx-disinherit="*"
              tal:define="ingredient_field field_name('ingredient_id')">
              <div class="position-relative">
                <input type="hidden" class="suggest-id"
                  name="${ingredient_field}" value="${used.ingredient.id}" />
                <input type="text"
                  name="${field_name('ingredient')}"
                  value="${used.ingredient.description}"
                  placeholder="eine Zutat ..."
                  class="form-control form-control-sm suggest-input"
                  _="on keyup debounced at 300ms
                      fetch `${request.route_url('suggest_ingredient')}?search=$${my value}`
                      then put it into the next .suggestion"
                />
                <div class="suggestion"></div>
              </div>
            </td>
            <td>
              <button type="button" class="btn btn-link btn-sm text-danger" _="on click remove closest tr">
                <i class="bi bi-x-lg"></i>
              </button>
            </td>
            <input type="hidden" name="${field_name('__end__')}" value="mapping" />
          </tr>

          <tr class="table-row template d-none">
            <input type="hidden" name="__start__" value="mapping" />
            <td class="text-end">
              <input type="text" name="amount" placeholder="1, 2, 3 ..."
                     class="form-control form-control-sm text-end" style="width:5rem" />
            </td>
            <td>
              <input type="text" name="unit" placeholder=""
                     class="form-control form-control-sm" style="width:5rem" />
            </td>
            <td hx-disinherit="*">
              <div class="position-relative">
                <input type="hidden" class="suggest-id" name="ingredient_id" value="" />
                <input type="text"
                  name="ingredient"
                  placeholder="eine weitere Zutat ..."
                  class="form-control form-control-sm suggest-input"
                  _="on keyup debounced at 300ms
                      fetch `${request.route_url('suggest_ingredient')}?search=$${my value}`
                      then put it into the next .suggestion"
                />
                <div class="suggestion"></div>
              </div>
            </td>
            <td>
              <button type="button" class="btn btn-link btn-sm text-danger" _="on click remove closest tr">
                <i class="bi bi-x-lg"></i>
              </button>
            </td>
            <input type="hidden" name="__end__" value="mapping" />
          </tr>
          <input type="hidden" name="${field_name('__end__')}" value="sequence" />
          <input type="hidden" class="next-sequence" value="${next_sequence()}"/>
        </tbody>
      </table>

    </form>

  </div>
</div>
